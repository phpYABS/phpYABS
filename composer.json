{
    "name": "phpyabs/phpyabs",
    "description": "Open source used book managment software. Ugly code, it was my very first project in 2003",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Davide Bellettini",
            "email": "davide.bellettini@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-bcmath": "*",
        "ext-pdo": "*",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.4",
        "moneyphp/money": "^4.6",
        "pentatrion/vite-bundle": "^8.0",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^2.1",
        "ronanguilloux/isocodes": "^2.3",
        "symfony/flex": "^2.5",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/psr-http-message-bridge": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-csrf": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/stimulus-bundle": "^2.23",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/uid": "^8.1",
        "symfony/ux-translator": "^2.23",
        "symfony/ux-vue": "^2.23",
        "symfony/validator": "^8.1",
        "symfony/var-dumper": "^8.1",
        "symfony/yaml": "^8.1",
        "tbbc/money-bundle": "^7.2",
        "twig/extra-bundle": "^2.12 || ^3.0",
        "twig/intl-extra": "^3.20",
        "twig/twig": "^2.12 || ^3.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.42",
        "friendsofphp/php-cs-fixer": "^3.73",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.2",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/maker-bundle": "^1.62",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.1"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "PhpYabs\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpYabs\\Tests\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    }
}
